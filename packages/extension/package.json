{
    "name": "words-lang",
    "displayName": "WORDS Specification Language",
    "description": "Syntax highlighting for .wds files and ```wds code fences in Markdown",
    "version": "0.2.2",
    "publisher": "KRUDSoftware",
    "repository": {
        "type": "git",
        "url": "https://github.com/krud-soft/words-lang"
    },
    "license": "MIT",
    "icon": "./icons/wds.png",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./dist/client.js",
    "scripts": {
        "build": "tsc",
        "list": "vsce ls",
        "build:watch": "tsc --watch",
        "copy": "node scripts/copy-deps.js",
        "package": "npm run build && npm run copy && vsce package --no-dependencies"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.74.0",
        "typescript": "^5.3.0"
    },
    "contributes": {
        "iconThemes": [
            {
                "id": "words-icons",
                "label": "WORDS Icons",
                "path": "./icons/words-icon-theme.json"
            }
        ],
        "languages": [
            {
                "id": "wds",
                "aliases": [
                    "WORDS Spec",
                    "wds"
                ],
                "extensions": [
                    ".wds"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "wds",
                "scopeName": "source.wds",
                "path": "./syntaxes/wds.tmGrammar.json"
            },
            {
                "scopeName": "markdown.wds.codeblock",
                "path": "./syntaxes/wds.markdown-injection.json",
                "injectTo": [
                    "text.html.markdown"
                ],
                "embeddedLanguages": {
                    "meta.embedded.block.wds": "wds"
                }
            }
        ]
    }
}